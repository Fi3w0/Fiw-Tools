# Build output
.gradle/
build/
out/
bin/
*.class

# Loom / NeoForge dev runs + caches
run/
run-server/
runs/
logs/
.fabric/
*.log

# Root/module dev runtime folders. Do not use **/client or **/server here:
# source packages may legitimately be named client/server.
/run/
/*/run/
/client/
/*/client/
/server/
/*/server/

# Packaged release jars
/jars/
/Jar/

# Keep the Gradle wrapper jar tracked even if jar rules get added later
!gradle/wrapper/gradle-wrapper.jar

# IDE / editors
.idea/
.vscode/
.eclipse/
.settings/
*.iml
*.ipr
*.iws
.project
.classpath

# OS cruft
.DS_Store
Thumbs.db

